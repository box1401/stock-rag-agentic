# ============== LLM ==============
GEMINI_API_KEY=                   # https://aistudio.google.com/apikey
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite

# ============== Embedding (Vertex AI) ==============
GOOGLE_APPLICATION_CREDENTIALS=   # path to service account json (optional in dev)
GCP_PROJECT_ID=
GCP_REGION=asia-east1
EMBEDDING_MODEL=text-embedding-005

# ============== Database ==============
# Local: docker-compose postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/compass
# Production: Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ============== Search / News ==============
TAVILY_API_KEY=
JINA_API_KEY=                     # optional, anonymous tier works
FINMIND_TOKEN=                    # optional, raises rate limit

# ============== Observability ==============
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============== Reranker ==============
RERANKER_URL=http://reranker:8001/rerank

# ============== App ==============
ENV=development
LOG_LEVEL=INFO
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
RATE_LIMIT_PER_MINUTE=20
